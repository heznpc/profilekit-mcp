  "repository": {
    "type": "git",
    "url": "git+https://github.com/heznpc/profilekit-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/heznpc/profilekit-mcp/issues"
  },
  "homepage": "https://github.com/heznpc/profilekit-mcp#readme"
